{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "linux-x86_64",
      "displayName": "Linux – x86_64 (64-bit Intel/AMD)",
      "description": "Standard x86_64 Linux build. Default for most desktop and server Linux hosts.",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "binaryDir": "${sourceDir}/../build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-arm64",
      "displayName": "Linux – arm64 / aarch64",
      "description": "64-bit ARM Linux build (Raspberry Pi 4/5, Ampere, AWS Graviton, etc.).",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "binaryDir": "${sourceDir}/../build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux – Release (portable binary, $ORIGIN RPATH)",
      "description": "Optimised release build with RPATH set to $ORIGIN/libs/ so dependencies can be bundled next to the binary for portable distribution.",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "binaryDir": "${sourceDir}/../build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "LINUX_RELEASE_BINS": "ON"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS – Apple Silicon (arm64)",
      "description": "Primary target: arm64, macOS 11.0+. Default for M-series Macs.",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "binaryDir": "${sourceDir}/../build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0"
      }
    },
    {
      "name": "macos-intel",
      "displayName": "macOS – Intel (x86_64)",
      "description": "Secondary target: x86_64, macOS 10.15+. Default for Intel Macs.",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "binaryDir": "${sourceDir}/../build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "10.15"
      }
    },
    {
      "name": "macos-universal",
      "displayName": "macOS – Universal Binary (release only)",
      "description": "Universal arm64+x86_64, macOS 11.0+, reproducible build. For distributable releases only.",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "binaryDir": "${sourceDir}/../build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0",
        "REPRODUCIBLE_BUILD": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-x86_64",
      "displayName": "Build – Linux x86_64",
      "configurePreset": "linux-x86_64"
    },
    {
      "name": "linux-arm64",
      "displayName": "Build – Linux arm64",
      "configurePreset": "linux-arm64"
    },
    {
      "name": "linux-release",
      "displayName": "Build – Linux Release (portable)",
      "configurePreset": "linux-release"
    },
    {
      "name": "macos-arm64",
      "displayName": "Build – macOS Apple Silicon",
      "configurePreset": "macos-arm64"
    },
    {
      "name": "macos-intel",
      "displayName": "Build – macOS Intel",
      "configurePreset": "macos-intel"
    },
    {
      "name": "macos-universal",
      "displayName": "Build – macOS Universal (release only)",
      "configurePreset": "macos-universal"
    }
  ]
}
